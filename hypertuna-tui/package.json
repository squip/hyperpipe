{
  "name": "hypertuna-tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "hypertuna-tui": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsup src/cli.tsx --format esm --out-dir dist --clean && node scripts/add-shebang.cjs dist/cli.js",
    "start": "node dist/cli.js",
    "test": "vitest run"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "nostr-tools": "^2.20.0",
    "react": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
