# Public Gateway deploy reference
#
# The recommended path is:
#   1. run `cd deploy && npm run deploy:init`
#   2. review the generated deploy/.env
#   3. run `cd deploy && npm run deploy:apply`
#
# This file exists as a documented reference for manual review and advanced edits.

# Deploy metadata
DEPLOY_PROFILE=open
# Exposure mode:
#   https-acme -> domain + Let's Encrypt
#   http       -> plain HTTP using a public IP or host
DEPLOY_EXPOSURE_MODE=https-acme
GATEWAY_HOST=your.domain
# Leave blank for DEPLOY_EXPOSURE_MODE=http
LETSENCRYPT_EMAIL=admin@example.com

# Public website (optional)
SITE_ENABLED=false
SITE_HOST=hyperpipe.io
SITE_WWW_HOST=www.hyperpipe.io
HYPERPIPE_SITE_ROOT=/srv/hyperpipe-site/current

# Gateway base configuration
GATEWAY_PUBLIC_URL=https://your.domain
GATEWAY_REGISTRATION_SECRET=replace-with-64-char-hex
GATEWAY_DISCOVERY_ENABLED=true
GATEWAY_DISCOVERY_OPEN_ACCESS=true
GATEWAY_DISCOVERY_DISPLAY_NAME=your.domain Public Gateway
GATEWAY_DISCOVERY_REGION=
GATEWAY_DISCOVERY_KEY_SEED=replace-with-stable-64-char-hex
GATEWAY_NOSTR_DISCOVERY_RELAYS=wss://relay.damus.io/,wss://relay.primal.net/,wss://nos.lol/
GATEWAY_REGISTRATION_REDIS=redis://redis:6379
GATEWAY_REGISTRATION_REDIS_PREFIX=public-gateway:your.domain:
GATEWAY_DEFAULT_TOKEN_TTL=3600
STORAGE_DIR=/data

# Gateway auth configuration
GATEWAY_AUTH_HOST_POLICY=open
GATEWAY_AUTH_MEMBER_DELEGATION=all-members
GATEWAY_AUTH_OPERATOR_PUBKEY=
# Optional verified-identity artifact generated offline via:
#   gateway-deploy attest-operator --request ./artifacts/operator-attestation-request.json --out ./artifacts/operator-attestation.json
GATEWAY_AUTH_OPERATOR_ATTESTATION_FILE=
GATEWAY_AUTH_ALLOWLIST_PUBKEYS=
GATEWAY_AUTH_ALLOWLIST_FILE=
GATEWAY_AUTH_ALLOWLIST_REFRESH_MS=5000
GATEWAY_AUTH_BLOCKLIST_PUBKEYS=
GATEWAY_AUTH_BLOCKLIST_FILE=/data/config/blocklist.json
GATEWAY_AUTH_BLOCKLIST_REFRESH_MS=5000
GATEWAY_AUTH_WOT_ROOT_PUBKEY=
GATEWAY_AUTH_WOT_MAX_DEPTH=1
GATEWAY_AUTH_WOT_MIN_FOLLOWERS_DEPTH2=0
GATEWAY_AUTH_WOT_RELAYS=
GATEWAY_AUTH_WOT_LOAD_TIMEOUT_MS=30000
GATEWAY_AUTH_WOT_REFRESH_MS=600000

# Relay host and dispatcher
GATEWAY_FEATURE_HYPERBEE_RELAY=true
GATEWAY_RELAY_STORAGE=/data/gateway-relay
GATEWAY_RELAY_NAMESPACE=replace-with-stable-namespace
GATEWAY_RELAY_REPLICATION_TOPIC=replace-with-stable-topic
GATEWAY_RELAY_ADMIN_PUBLIC_KEY=replace-with-64-char-hex
GATEWAY_RELAY_ADMIN_SECRET_KEY=replace-with-64-char-hex
GATEWAY_FEATURE_RELAY_DISPATCHER=false
GATEWAY_FEATURE_RELAY_TOKEN_ENFORCEMENT=true
GATEWAY_DISPATCHER_MAX_CONCURRENT=3
GATEWAY_DISPATCHER_INFLIGHT_WEIGHT=25
GATEWAY_DISPATCHER_LATENCY_WEIGHT=1
GATEWAY_DISPATCHER_FAILURE_WEIGHT=500
GATEWAY_DISPATCHER_REASSIGN_LAG=500
GATEWAY_DISPATCHER_CIRCUIT_BREAKER_THRESHOLD=5
GATEWAY_DISPATCHER_CIRCUIT_BREAKER_TIMEOUT_MS=60000

# Blind peer settings
GATEWAY_BLINDPEER_ENABLED=true
GATEWAY_BLINDPEER_STORAGE=/data/blind-peer
GATEWAY_BLINDPEER_PORT=31000
GATEWAY_BLINDPEER_MAX_BYTES=26843545600
GATEWAY_BLINDPEER_GC_INTERVAL_MS=300000
GATEWAY_BLINDPEER_TRUSTED_PATH=/data/blind-peer/trusted-peers.json

# Operational settings
GATEWAY_OPEN_JOIN_POOL_TTL=0
GATEWAY_METRICS_ENABLED=true
GATEWAY_LOG_DIR=/app/public-gateway/logs
GATEWAY_LOG_PREFIX=public-gateway
GATEWAY_LOG_ROTATE_MS=1200000
GATEWAY_LOG_RETENTION_MS=604800000
