GATEWAY_PROFILE=internet
GATEWAY_HOST=gateway.example.com
LETSENCRYPT_EMAIL=admin@example.com
GATEWAY_PUBLIC_URL=https://gateway.example.com
GATEWAY_TLS_ENABLED=false

GATEWAY_METRICS_ENABLED=true
GATEWAY_METRICS_PATH=/metrics
GATEWAY_LOG_DIR=/app/public-gateway/logs
GATEWAY_LOG_PREFIX=public-gateway
GATEWAY_LOG_ROTATE_MS=1800000
GATEWAY_LOG_RETENTION_MS=18000000
GATEWAY_HOST_LOG_PATH=./logs
GATEWAY_RATELIMIT_ENABLED=true
GATEWAY_RATELIMIT_WINDOW=60
GATEWAY_RATELIMIT_MAX=120

GATEWAY_REGISTRATION_REDIS=redis://redis:6379
GATEWAY_REGISTRATION_REDIS_PREFIX=public-gateway:${GATEWAY_HOST}:
GATEWAY_REGISTRATION_TTL=0
GATEWAY_MIRROR_METADATA_TTL=0
GATEWAY_OPEN_JOIN_POOL_TTL=0

GATEWAY_FEATURE_HYPERBEE_RELAY=true
GATEWAY_FEATURE_RELAY_DISPATCHER=true
GATEWAY_FEATURE_RELAY_TOKEN_ENFORCEMENT=true
GATEWAY_RELAY_STORAGE=/data/gateway-relay
GATEWAY_RELAY_NAMESPACE=public-gateway-relay
GATEWAY_RELAY_REPLICATION_TOPIC=public-gateway-relay
GATEWAY_RELAY_SEED=
GATEWAY_RELAY_ADMIN_PUBLIC_KEY=
GATEWAY_RELAY_ADMIN_SECRET_KEY=
GATEWAY_BLINDPEER_ENABLED=true
GATEWAY_BLINDPEER_STORAGE=/data/blind-peer

GATEWAY_ENABLE_MULTI=true
GATEWAY_OPERATOR_NSEC_HEX=
GATEWAY_OPERATOR_PUBKEY_HEX=
GATEWAY_POLICY=OPEN
GATEWAY_ALLOW_LIST=
GATEWAY_BAN_LIST=
GATEWAY_DISCOVERY_RELAYS=wss://relay.damus.io,wss://nos.lol
GATEWAY_INVITE_ONLY=false

GATEWAY_AUTH_JWT_SECRET=change-me
GATEWAY_RELAY_TOKEN_JWT_SECRET=
GATEWAY_AUTH_TOKEN_TTL_SEC=3600
GATEWAY_AUTH_CHALLENGE_TTL_MS=120000
GATEWAY_AUTH_WINDOW_SEC=300

GATEWAY_ADMIN_UI_ENABLED=true
GATEWAY_ADMIN_UI_PATH=/admin
GATEWAY_ADMIN_SESSION_COOKIE_NAME=ht_gateway_admin
GATEWAY_ADMIN_SESSION_TTL_SEC=3600
GATEWAY_ADMIN_ACTIVITY_RETENTION=5000
GATEWAY_ADMIN_STATE_REDIS_PREFIX=gateway:admin:
GATEWAY_ADMIN_PROFILE_SEARCH_LIMIT=12
GATEWAY_ADMIN_PROFILE_QUERY_TIMEOUT_MS=4000
GATEWAY_ADMIN_PROFILE_CACHE_TTL_SEC=1800
GATEWAY_ADMIN_PROFILE_SEARCH_RELAYS=
GATEWAY_ADMIN_PROFILE_PARTICIPANT_REFRESH_MS=120000
GATEWAY_ADMIN_PROFILE_PARTICIPANT_EVENT_LIMIT=800
GATEWAY_ADMIN_PROFILE_CANDIDATE_RESOLVE_LIMIT=240
